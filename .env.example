# ============================================================
# MyCoursePlan — Environment Variables
# ============================================================
# Copy this file as:
#   .env.staging    — for local dev pointing at staging Firebase
#   .env.production — for local dev pointing at production Firebase
#   .env            — default (typically = staging)
#
# In Netlify: set these in Site settings → Environment variables
# ============================================================

# ---- Firebase Client SDK (frontend, VITE_ prefix) ----
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_VAPID_KEY=

# ---- Firebase Admin SDK (Netlify Functions, server-side) ----
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ---- AI Provider ----
GEMINI_API_KEY=

# ---- Payment Provider (Finik.kg) ----
FINIK_API_KEY=
FINIK_SECRET_KEY=
FINIK_API_URL=https://api.finik.kg
FINIK_TESTING=true
# Legacy FreedomPay (being replaced):
# FREEDOMPAY_MERCHANT_ID=
# FREEDOMPAY_SECRET_KEY=
# FREEDOMPAY_API_URL=
# FREEDOMPAY_TESTING=true
