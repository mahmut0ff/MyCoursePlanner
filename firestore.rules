rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Super admin can do everything
    function isSuperAdmin() {
      return request.auth != null && request.auth.token.role == 'super_admin';
    }

    // 1b. Organization Access Check
    // OPTIMIZED: worst-case 2 reads (membership check + user doc), not 3.
    // Membership check is cheapest (1 exists() read, no data transfer).
    // If that fails, single user doc read checks both legacy fields.
    function hasOrgAccess(orgId) {
      return request.auth != null && (
        exists(/databases/$(database)/documents/users/$(request.auth.uid)/memberships/$(orgId)) ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.organizationId == orgId ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.activeOrgId == orgId
      );
    }

    // 2. Users — can read own profile, staff can read org members, super admin reads all
    match /users/{userId} {
      allow read: if isSuperAdmin() || request.auth.uid == userId || 
        (request.auth != null && resource.data.organizationId != null && 
         resource.data.organizationId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.organizationId);
      
      // Self-service signup: only teacher/student. Admins (owners of учебных
      // центров) are provisioned server-side via the super-admin panel after a
      // demo call, so they must NOT be creatable from the client.
      allow create: if isSuperAdmin() || (
        request.auth.uid == userId &&
        (!('role' in request.resource.data) ||
          request.resource.data.role in ['teacher', 'student']) &&
        (!('organizationId' in request.resource.data) || request.resource.data.organizationId == '') &&
        (!('activeOrgId' in request.resource.data) || request.resource.data.activeOrgId == '')
      );

      allow update: if isSuperAdmin() || (
        request.auth.uid == userId &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'organizationId', 'activeOrgId', 'activeRole', 'branchIds'])
      );

      allow delete: if isSuperAdmin();
      
      match /memberships/{orgId} {
        allow read: if request.auth != null;
        allow write: if isSuperAdmin();
      }
    }

    // 3. Organizations and Public/Global Data
    match /organizations/{orgId} {
      allow read: if request.auth != null || resource.data.isPublic == true;
      allow write: if isSuperAdmin() || (request.auth != null && request.auth.uid == resource.data.ownerId);

      match /aiLeads/{leadId} {
        allow read, write: if isSuperAdmin() || (
           hasOrgAccess(orgId) && (
               request.auth.uid == get(/databases/$(database)/documents/organizations/$(orgId)).data.ownerId ||
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'manager'
           )
        );
      }

      // RBAC roles — readable by org members (the Team & Roles UI resolves the
      // current user's role client-side). All writes go through the backend
      // (api-roles, Admin SDK), so direct SDK writes are restricted to super admin.
      match /roles/{roleId} {
        allow read: if isSuperAdmin() || hasOrgAccess(orgId);
        allow write: if isSuperAdmin();
      }

      // AI usage meter — read by the AI hub usage panel; written only by the
      // backend (Admin SDK) via recordAiUsage, so direct SDK writes are denied.
      match /aiUsage/{period} {
        allow read: if isSuperAdmin() || hasOrgAccess(orgId);
        allow write: if false;
      }
    }
    
    match /organizationAIManager/{orgId} {
      // Chat widget checks isActive — require at least auth (public Telegram bot uses Admin SDK)
      allow read: if request.auth != null;
      allow write: if isSuperAdmin() || (request.auth != null && request.auth.uid == get(/databases/$(database)/documents/organizations/$(orgId)).data.ownerId);
    }
    
    match /orgMembers/{orgId}/members/{userId} {
      allow read: if request.auth != null;
      allow write: if isSuperAdmin();
    }

    // Real-time presence (online / last-seen heartbeats).
    // Each user writes ONLY their own presence doc; org members read presence
    // for their organization (e.g. a director viewing the teacher list).
    match /presence/{userId} {
      allow read: if isSuperAdmin() || hasOrgAccess(resource.data.organizationId);
      // Own doc only, and its org must be one the writer actually belongs to —
      // otherwise a user could stamp a foreign tenant's id onto their presence
      // and inject a phantom entry into that org's presence query.
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.organizationId is string
        && hasOrgAccess(request.resource.data.organizationId);
    }

    // 4. Exams & Lessons (Org-scoped read for students, edited via backend)
    match /lessonPlans/{lessonId} {
      allow read: if isSuperAdmin() || hasOrgAccess(resource.data.organizationId);
      allow write: if isSuperAdmin();
    }
    match /exams/{examId} {
      // All exam reads go through backend API (Admin SDK bypasses rules).
      // Restrict SDK reads to org members for defense-in-depth.
      allow read: if isSuperAdmin() || hasOrgAccess(resource.data.organizationId);
      allow write: if isSuperAdmin();
      match /questions/{questionId} {
        // Questions inherit exam's org scope.
        allow read: if isSuperAdmin() || hasOrgAccess(get(/databases/$(database)/documents/exams/$(examId)).data.organizationId);
        allow write: if isSuperAdmin();
      }
    }
    match /examRooms/{roomId} {
      // Rooms are read via backend API. Restrict SDK to org members.
      allow read: if isSuperAdmin() || hasOrgAccess(resource.data.organizationId);
      allow write: if isSuperAdmin();
    }

    // 5. Exam Attempts — Strict Isolation
    // Only the student who took it, or super admin (staff use backend API)
    match /examAttempts/{attemptId} {
      allow read: if isSuperAdmin() || (request.auth != null && resource.data.studentId == request.auth.uid);
      allow write: if isSuperAdmin(); // Created strictly via backend API now
    }

    // 6. Certificates — Public if you have the ID, but created via backend
    match /certificates/{certId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // 7. Gamification — Strict Isolation
    match /gamification/{docId} {
      allow read: if isSuperAdmin() || (request.auth != null && docId == request.auth.uid);
      allow write: if isSuperAdmin(); // Handled exclusively by backend now
    }
    match /xpEvents/{eventId} {
      allow read: if isSuperAdmin() || (request.auth != null && resource.data.userId == request.auth.uid);
      allow write: if isSuperAdmin(); // Handled exclusively by backend now
    }

    // 8. Quizzes & Live Sessions
    match /quizzes/{quizId} {
      allow read: if isSuperAdmin() || hasOrgAccess(resource.data.organizationId);
      allow write: if isSuperAdmin();
      match /questions/{questionId} {
        allow read: if isSuperAdmin() || hasOrgAccess(get(/databases/$(database)/documents/quizzes/$(quizId)).data.organizationId);
        allow write: if isSuperAdmin();
      }
    }
    match /quizSessions/{sessionId} {
      // PIN-based access model (like Kahoot): any authenticated user who knows
      // the sessionId can read the session. The PIN/ID itself is the access control.
      allow read: if request.auth != null;
      allow write: if isSuperAdmin();
      match /participants/{participantId} {
        allow read: if request.auth != null;
        allow write: if isSuperAdmin();
      }
      match /answers/{answerId} {
        allow read: if request.auth != null;
        allow write: if isSuperAdmin(); // Created via backend
      }
    }
    match /quizShares/{shareId} {
      // Quiz shares are used for cross-tenant sharing or public joining
      allow read: if request.auth != null;
      allow write: if isSuperAdmin();
    }
    match /quizAnalytics/{analyticsId} {
      allow read: if isSuperAdmin();
      allow write: if isSuperAdmin();
    }

    // 9. Notifications
    match /notifications/{notifId} {
      allow read: if isSuperAdmin() || (request.auth != null && resource.data.recipientId == request.auth.uid);
      allow write: if isSuperAdmin() || (request.auth != null && resource.data.recipientId == request.auth.uid);
    }

    // 10. Chat System
    match /chatRooms/{roomId} {
      allow read: if isSuperAdmin() || (request.auth != null && request.auth.uid in resource.data.participantIds);
      
      // Allow participant to update ONLY lastMessageAt, lastMessagePreview, updatedAt, and their own lastReadAt
      allow update: if isSuperAdmin() || (
        request.auth != null && 
        request.auth.uid in resource.data.participantIds &&
        request.resource.data.diff(resource.data).affectedKeys().hasAny(['lastMessageAt', 'lastMessagePreview', 'updatedAt', 'participants']) &&
        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['id', 'organizationId', 'type', 'participantIds', 'isArchived', 'createdBy']))
      );

      // Create/Delete must go through backend
      allow create, delete: if isSuperAdmin(); 

      
      match /messages/{messageId} {
        allow read: if isSuperAdmin() || (request.auth != null && request.auth.uid in get(/databases/$(database)/documents/chatRooms/$(roomId)).data.participantIds);
        
        allow create: if isSuperAdmin() || (
          request.auth != null && 
          request.resource.data.senderId == request.auth.uid &&
          request.auth.uid in get(/databases/$(database)/documents/chatRooms/$(roomId)).data.participantIds
        );
        
        allow update: if isSuperAdmin() || (
          request.auth != null && 
          resource.data.senderId == request.auth.uid &&
          request.resource.data.senderId == resource.data.senderId // Prevent sender spoofing on edit
        );
        
        allow delete: if isSuperAdmin(); // Hard delete only via backend
      }

      // Typing indicators: participant can write/delete own entry, read all
      match /typing/{typingUserId} {
        allow read: if request.auth != null && request.auth.uid in get(/databases/$(database)/documents/chatRooms/$(roomId)).data.participantIds;
        allow write, delete: if request.auth != null && request.auth.uid == typingUserId;
      }
    }

    // 10b. Support desk — one thread per user, doc id === uid.
    //
    // Reads are direct (the UI is a live onSnapshot); every write goes through
    // api-support with the Admin SDK. That split is deliberate: `senderSide`,
    // the denormalised org/role snapshot and the unread counters decide what the
    // super admin sees, so none of them may be client-writable.
    match /supportThreads/{userId} {
      allow read: if isSuperAdmin() || (request.auth != null && request.auth.uid == userId);
      allow write: if false;

      match /messages/{messageId} {
        allow read: if isSuperAdmin() || (request.auth != null && request.auth.uid == userId);
        allow write: if false;
      }

      // Typing indicators are ephemeral, self-keyed and carry nothing worth
      // spoofing, so they are the one part of a thread written client-side.
      match /typing/{typingUserId} {
        allow read: if isSuperAdmin() || (request.auth != null && request.auth.uid == userId);
        allow write, delete: if request.auth != null && request.auth.uid == typingUserId
                             && (isSuperAdmin() || request.auth.uid == userId);
      }
    }

    // 11. System Data (Admins only)
    match /subscriptions/{subId} { allow read, write: if isSuperAdmin(); }
    match /payments/{paymentId} { allow read, write: if isSuperAdmin(); }
    match /auditLogs/{logId} { allow read, write: if isSuperAdmin(); }
    match /featureFlags/{flagId} { allow read: if request.auth != null; allow write: if isSuperAdmin(); }
    match /orgOverrides/{overrideId} { allow read, write: if isSuperAdmin(); }
    match /orgNotes/{noteId} { allow read, write: if isSuperAdmin(); }
    match /systemErrors/{errorId} { allow read, write: if isSuperAdmin(); }
    match /courseRequests/{reqId} { allow read, write: if false; } // Handled entirely via backend
    match /demoRequests/{reqId} { allow read, write: if false; }   // Handled entirely via backend (api-demo-requests)

    // Telegram onboarding / login — all written & read by the backend (Admin SDK).
    match /orgJoinCodes/{code} { allow read, write: if false; }
    match /orgOnboarding/{orgId} { allow read, write: if false; }
    match /orgClaimTokens/{token} { allow read, write: if false; }
    match /telegramRegistrations/{chatId} { allow read, write: if false; }
    match /telegramLoginTokens/{token} { allow read, write: if false; }

  }
}
